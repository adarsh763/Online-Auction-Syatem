<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <%- include('partials/header-app') %>

    <!-- Outbid Alert Banner -->
    <div id="outbid-banner" class="outbid-banner"></div>

    <!-- Status Banner -->
    <div id="status-banner" class="status-banner"></div>

    <!-- Main Content -->
    <div class="container py-4">
        <div class="row g-4">
            <!-- Left Column: Auction Details -->
            <div class="col-lg-7">
                <div class="glass-card p-4 mb-4">
                    <img id="auction-image" class="auction-image mb-4" src="" alt="Auction item"
                        style="display: none; width: 100%; max-height: 400px; object-fit: cover; border-radius: var(--radius-sm);" />
                    <span class="story-badge mb-2 d-inline-block">AUCTION ITEM</span>
                    <h1 id="auction-title" class="auction-title">Loading auction...</h1>
                    <div class="story-divider mb-3" style="margin: 0;"></div>
                    <p id="auction-description" style="color: var(--text-secondary); margin-top: 0.75rem;">
                        Loading description...
                    </p>
                    <div class="auction-meta mt-4 py-3" style="border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
                        <span class="small" style="color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600; font-size: 0.7rem;">SELLER</span>
                        <strong id="seller-name" style="color: var(--accent-dark); margin-left: 0.5rem;">—</strong>
                    </div>
                </div>

                <!-- Bid History -->
                <div class="glass-card p-0 overflow-hidden mb-4">
                    <div class="d-flex justify-content-between align-items-center px-4 py-3"
                        style="background: var(--accent-glow); border-bottom: 1px solid var(--border);">
                        <span style="font-weight: 600; font-size: 0.8rem; letter-spacing: 1.5px; text-transform: uppercase; color: var(--accent-dark);">Bid History</span>
                        <span class="bid-count-badge" id="bid-count">0</span>
                    </div>
                    <div id="bid-history" class="bid-history p-3" style="max-height: 500px; overflow-y: auto;">
                        <div class="bid-empty-state">🔨 No bids yet.</div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Bidding Panel -->
            <div class="col-lg-5">
                <div class="glass-card mb-4 text-center p-4">
                    <div class="story-badge mb-2 mx-auto">CURRENT BID</div>
                    <div id="current-bid" class="current-bid-amount mb-1">$0.00</div>
                    <div style="color: var(--text-secondary); font-size: 0.9rem;">
                        held by <span id="highest-bidder" style="font-weight: 700; color: var(--text-primary);">No bids yet</span>
                    </div>
                </div>

                <div class="glass-card mb-4 p-4 text-center">
                    <div class="story-badge mb-3 mx-auto">TIME LEFT</div>
                    <div id="countdown-timer" class="countdown-display d-flex justify-content-center gap-3">
                        <div class="countdown-unit">
                            <span id="cd-days" class="countdown-value">00</span>
                            <small class="countdown-label">DAYS</small>
                        </div>
                        <div class="countdown-unit">
                            <span id="cd-hours" class="countdown-value">00</span>
                            <small class="countdown-label">HOURS</small>
                        </div>
                        <div class="countdown-unit">
                            <span id="cd-minutes" class="countdown-value">00</span>
                            <small class="countdown-label">MINS</small>
                        </div>
                        <div class="countdown-unit">
                            <span id="cd-seconds" class="countdown-value">00</span>
                            <small class="countdown-label">SECS</small>
                        </div>
                    </div>
                </div>

                <div class="glass-card p-4">
                    <div class="story-badge mb-3">PLACE YOUR BID</div>
                    <div class="d-flex gap-2 mb-3">
                        <button class="btn btn-sm quick-bid-btn flex-fill" data-inc="10">+$10</button>
                        <button class="btn btn-sm quick-bid-btn flex-fill" data-inc="50">+$50</button>
                        <button class="btn btn-sm quick-bid-btn flex-fill" data-inc="100">+$100</button>
                    </div>
                    <div class="bid-input-group d-flex gap-2">
                        <input type="number" id="bid-amount" class="form-input-custom"
                            placeholder="Enter amount ($)" min="0.01" step="0.01" />
                        <button id="bid-btn" class="btn-bid">🔨 Place Bid</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Winner Celebration Modal -->
    <div id="winner-modal" class="winner-modal"></div>
    <!-- Toast Notifications Container -->
    <div id="toast-container" class="toast-container"></div>

    <%- include('partials/footer') %>
    <script>
        // Directly set to window to ensure visibility for socket-client.js
        window.currentAuctionId = "<%= typeof auctionId !== 'undefined' ? auctionId : '' %>";
    </script>
    <script src="/js/socket-client.js"></script>
</body>
</html>
