<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
    <%- include('partials/header-app') %>

    <!-- Dashboard -->
    <div class="container py-5">
        <h2 class="hero-title" style="font-size: 2rem;">Welcome, <span id="welcome-name" style="color: var(--accent-dark);">User</span></h2>
        <p style="color: var(--text-muted); margin-bottom: 2rem;">Here's your auction activity</p>

        <!-- Loading -->
        <div id="dashboard-loading" class="text-center py-5" style="display: flex; justify-content: center;">
            <div class="spinner-border" style="color: var(--accent);" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>

        <!-- Dashboard Content -->
        <div id="dashboard-content" style="display: none;">
            <!-- Stats Cards -->
            <div class="row g-4 mb-4">
                <div class="col-md-4">
                    <div class="glass-card stat-card">
                        <div class="stat-icon">🏷️</div>
                        <div class="stat-value" id="stat-created">0</div>
                        <div class="stat-label">Auctions Created</div>
                    </div>
                </div>
                <!-- ... existing cards ... -->
                <div class="col-md-4">
                    <div class="glass-card stat-card">
                        <div class="stat-icon">🔥</div>
                        <div class="stat-value" id="stat-bidding">0</div>
                        <div class="stat-label">Active Bids</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="glass-card stat-card">
                        <div class="stat-icon">🏆</div>
                        <div class="stat-value" id="stat-won">0</div>
                        <div class="stat-label">Auctions Won</div>
                    </div>
                </div>
            </div>

            <!-- Tabs -->
            <ul class="nav nav-tabs dashboard-tabs mb-4" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-created" type="button"
                        role="tab">My Auctions</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-bidding" type="button"
                        role="tab">Bidding On</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-won" type="button"
                        role="tab">Won</button>
                </li>
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="tab-created" role="tabpanel">
                    <div id="my-auctions-list" class="dashboard-list"></div>
                </div>
                <div class="tab-pane fade" id="tab-bidding" role="tabpanel">
                    <div id="bidding-list" class="dashboard-list"></div>
                </div>
                <div class="tab-pane fade" id="tab-won" role="tabpanel">
                    <div id="won-list" class="dashboard-list"></div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
    <script src="/js/dashboard.js"></script>
</body>
</html>
